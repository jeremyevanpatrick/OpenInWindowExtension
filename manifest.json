{
  "manifest_version": 3,
  "name": "Open Link in Window",
  "version": "1.0.0",
  "description": "Right-click any link to open it in a specific Chrome window.",
  "permissions": [
    "contextMenus",
    "tabs"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
